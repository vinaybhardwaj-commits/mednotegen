# ---- MedNoteGen environment ----

# Neon Postgres (HTTP driver). Use the pooled connection string.
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# Protected migrate/seed route
MIGRATION_SECRET="change-me"

# Token gate (?t=...) — like evenos-revenue / evenos-status
APP_ACCESS_TOKEN="change-me"

# ---- Vertex AI / Gemini (mirror ETA: clinical-infra / asia-northeast1) ----
GCP_PROJECT_ID="clinical-infra"
GCP_LOCATION="asia-northeast1"
# Service-account JSON, base64-encoded (decoded at runtime). Keep OUT of git.
GCP_SA_KEY_BASE64=""
GEMINI_REASONING_MODEL="gemini-2.5-pro"
GEMINI_UTILITY_MODEL="gemini-2.5-flash"
# Master switch; mirrors ETA's GEMINI_ALL
GEMINI_ALL="1"
